# CurseForge automatic packaging configuration
# Docs: https://support.curseforge.com/support/solutions/articles/9000197281-automatic-packaging

package-as: ItemTier

enable-nolib-creation: no

externals:
  Baganator:
    url: https://github.com/Cidan/Baganator.git
    tag: latest

ignore:
  - .gitignore
  - .vscode
